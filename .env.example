ENVIRONMENT=test

# Origin pool settings
MAX_CONNECTIONS=80
CLIENT_TTL_MS=300000
CONNECT_TIMEOUT_MS=10000
HEADERS_TIMEOUT_MS=30000
BODY_TIMEOUT_MS=60000

# Per-request outer timeout
REQUEST_TIMEOUT_MS=30000

# Auth tokens for origin forwarding (set when *OriginAuthHeader is configured in cacheConfiguration)
API_ORIGIN_AUTH_TOKEN=secret_auth_token
DEFAULT_ORIGIN_AUTH_TOKEN=secret_auth_token

# Optional: comma-separated additional paths to bypass cache logic
# RESERVED_PATHS=/health,/ping

# Load test mode: replace origin fetches with mock responses
# HDB_LOAD_TEST_MODE=true
