{
	"name": "template-site-cache",
	"version": "1.0.0",
	"description": "Harper Site Cache Template",
	"type": "module",
	"scripts": {
		"generate:types": "graphql-codegen --config codegen.ts",
		"build": "tsc",
		"dev": "tsc; harperdb dev .",
		"test:unit": "node --test --import tsx tests/unit/*.test.ts",
		"test:integration": "npx c8 --reporter=lcov node --test tests/integration/integration.test.js",
		"lint": "eslint src",
		"format": "prettier --write .",
		"postinstall": "npm link harperdb",
		"postuninstall": "npm link harperdb"
	},
	"prettier": "@harperdb/code-guidelines/prettier",
	"author": "HarperDB, Inc.",
	"license": "Apache-2.0",
	"devDependencies": {
		"@graphql-codegen/cli": "^5.0.3",
		"@graphql-codegen/typescript": "^4.1.2",
		"@graphql-codegen/typescript-operations": "^4.4.0",
		"@harperdb/code-guidelines": "^0.0.2",
		"@types/node": "^22.19.13",
		"c8": "^10.1.3",
		"eslint": "^10.4.0",
		"graphql": "^16.10.0",
		"prettier": "^3.4.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.57.0"
	},
	"dependencies": {
		"undici": "^7.22.0"
	}
}
